# ===========================================
# Libby D. Bot API Server Configuration
# ===========================================

# PostgreSQL Database Configuration (Required)
# PostgreSQL is the default and recommended database backend
# Using pgvector extension for vector similarity search
POSTGRES_DB=libby
POSTGRES_USER=libby
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE

# Database URL for embeddings (auto-generated from above settings in docker-compose)
# For local development, you can set this directly:
# EMBED_DB=postgresql://libby:CHANGE_ME_SECURE_PASSWORD_HERE@localhost:5432/libby

# Alternative database backends (not recommended for production):
#   - DuckDB: duckdb:///path/to/embeddings.duckdb
#   - SQLite: sqlite:///path/to/embeddings.db

# Embedding model to use
# Options: embeddinggemma, mxbai-embed-large, gemini-embedding-001
EMBEDDING_MODEL=mxbai-embed-large

# Default collection name for document embeddings
COLLECTION_NAME=main

# ===========================================
# LLM Provider Configuration
# ===========================================

# Ollama server URL (for local LLM inference)
OLLAMA_HOST=http://localhost:11434

# Google Gemini API key (for Gemini embeddings and chat)
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI API key (for GPT-4o)
OPENAI_API_KEY=your-openai-api-key-here

# ===========================================
# PostgreSQL Backup Configuration
# ===========================================

# Number of days to keep backups (default: 7)
BACKUP_RETENTION_DAYS=7

# Backup schedule in cron format (default: daily at 2 AM)
# Format: minute hour day month weekday
BACKUP_SCHEDULE=0 2 * * *

# ===========================================
# Document Watcher Configuration
# ===========================================

# Cron schedule for document watcher (default: every 5 minutes)
# Format: minute hour day month weekday
CRON_SCHEDULE=*/5 * * * *

# Chunk size for document processing
CHUNK_SIZE=800

# Overlap between chunks
CHUNK_OVERLAP=100

# ===========================================
# SFTP Server Configuration
# ===========================================

# SFTP user (defined in docker-compose.yml)
# SFTP_USER=libby

# SFTP port (mapped in docker-compose.yml)
# SFTP_PORT=2222

# To set up SSH key authentication:
# 1. Generate SSH keys: ssh-keygen -t ed25519 -f ./ssh_keys/ssh_host_ed25519_key
# 2. Create authorized_keys: cp ./ssh_keys/ssh_host_ed25519_key.pub ./ssh_keys/authorized_keys
# 3. Set permissions: chmod 600 ./ssh_keys/*
#
# Connect with: sftp -P 2222 libby@localhost
